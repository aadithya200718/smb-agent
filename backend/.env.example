# ==============================================================================
# AI WhatsApp Business Assistant — Environment Variables
# ==============================================================================
# Copy this file to .env and fill in your actual values.
#   cp .env.example .env
# ==============================================================================

# ── Server ───────────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production
DEBUG=true                       # Enable debug mode & auto-reload

# ── MongoDB ──────────────────────────────────────────────────────────────────
# Local:  mongodb://localhost:27017
# Atlas:  mongodb+srv://<user>:<pass>@cluster.xxxxx.mongodb.net
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=whatsapp_business_agent

# ── Qdrant Vector Database ──────────────────────────────────────────────────
# Local (Docker): http://localhost:6333
# Cloud:          https://<cluster>.qdrant.io
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                  # Leave empty for local; required for cloud

# ── Groq LLM (Phase 2+) ────────────────────────────────────────────────
GROQ_API_KEY=your_groq_key_here

# ── Twilio / WhatsApp (Phase 3+) ────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
WEBHOOK_BASE_URL=https://your-domain.ngrok.io

# ── Razorpay Payments (Phase 4+) ────────────────────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_key_here
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# ── Security / JWT ──────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-random-256-bit-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440      # 24 hours
